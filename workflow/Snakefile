# ==============================================================================
# 3. Rule: Get Target Region
# ==============================================================================
rule run_get_target_and_second_region:
    input:
        target_ref_file = get_target_ref,
        second_assembly_file = get_second_asm,
        error_dir = rules.target_merge_nucflag_errors.output.merged_dir,
    output:
        error_coordinates_file = os.path.join(OUTDIR, "{sample}", 'error_cen_array_list.bed'),
        target_cen_array = directory(os.path.join(OUTDIR, "{sample}", 'target_cen_array')),
        paf_file = os.path.join(OUTDIR, "{sample}", 'all.cenarray.fa.paf'),
        matching_records_file = os.path.join(OUTDIR, "{sample}", 'cenpairs.xls'),
        second_asm_array_bed = os.path.join(OUTDIR, "{sample}", 'second_asm_array.nucflag.bed'),
        repair_table = os.path.join(OUTDIR, "{sample}", 'region_match.all.xls'),
        second_asm_array = directory(os.path.join(OUTDIR, "{sample}", 'second_asm_array'))
    threads: THREADS_ALN
    conda:
        "envs/env.yaml"
    resources:
        mem = MEM_ALN
    log:
        os.path.join(LOGS_DIR, "{sample}", "run_get_target_and_second_region.log")
    benchmark:
        os.path.join(BMKS_DIR, "{sample}", "run_get_target_and_second_region.tsv")
    params:
        outdir = lambda w: os.path.join(OUTDIR, w.sample),
        MAPQ_thr = MAPQ_thr,
        break_contig_merge_thr = break_contig_merge_thr,
        min_array_thr = min_array_thr,
        overlap_merge_thr = overlap_merge_thr,
    shell:
        """
        python workflow/script/getTargetRegionAndSecondRegion.py \
            -tr {input.target_ref_file} \
            -sr {input.second_assembly_file} \
            -e {input.error_dir} \
            -mt {threads} \
            -mq {params.MAPQ_thr} \
            -bc {params.break_contig_merge_thr} \
            -ma {params.min_array_thr} \
            -om {params.overlap_merge_thr} \
            -o {params.outdir} 2> {log}
        """

