import os

# ==============================================================================
# 1. Config & Global Variables
# ==============================================================================
SAMPLES = list(config.get("samples", {}).keys())

# 全局参数提取
OUTDIR = config.get("outdir", "results")
LOGS_DIR = config.get("logs_dir", "logs")
BMKS_DIR = config.get("bmks_dir", "bmks")

THREADS_ALN = int(config.get("threads", 1))
MEM_ALN = str(config.get("mem_aln", "10GB"))

nucflag_filter = config.get("nucflag_filter", "")
MAPQ_thr = config.get("MAPQ_thr", 20)
break_contig_merge_thr = config.get("break_contig_merge_thr", 5000)
min_array_thr = config.get("min_array_thr", 100000)
overlap_merge_thr = config.get("overlap_merge_thr", 0.3)
kmer_size = config.get("kmer_size", 5000)
kmer_number = config.get("kmer_number", 2000)
extend_length = config.get("extend_length", 10000)
merge_distance = config.get("merge_distance", 500000)
rollback_mode = int(config.get("rollback", 1))

# ==============================================================================
# Helper Functions: 获取特定样本的配置
# ==============================================================================
def get_sample_val(sample, key, default=None):
    return config.get("samples", {}).get(sample, {}).get(key, default)

def get_target_ref(wildcards):
    return get_sample_val(wildcards.sample, "target_ref_file")

def get_second_asm(wildcards):
    return get_sample_val(wildcards.sample, "second_assembly_file")


