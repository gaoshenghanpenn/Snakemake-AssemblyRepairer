# ==============================================================================
# 9. Make QC report
# ==============================================================================
def get_final_error_source(wildcards):
    if rollback_mode == 1:
        return rules.afterRB_merge_nucflag_errors.output.merged_dir
    else:
        return rules.repaired_merge_nucflag_errors.output.merged_dir

def get_region_source(wildcards):
    if rollback_mode == 1:
        return rules.run_rollback.output.final_bed
    else:
        return rules.merge_and_repair_assembly.output.out_bed

rule get_QC_report:
    input:
        target_nucflag = rules.target_merge_nucflag_errors.output.merged_dir,
        final_nucflag = get_final_error_source,
        region_source = get_region_source,
    output:
        qc_report = os.path.join(OUTDIR, "{sample}", 'QC_report.xls')
    log:
        os.path.join(LOGS_DIR, "{sample}", "get_QC_report.log")
    benchmark:
        os.path.join(BMKS_DIR, "{sample}", "get_QC_report.tsv") 
    threads: 1
    shell:
        """
        python workflow/script/make_QC_report.py \
            -r {input.region_source} \
            -tn {input.target_nucflag} \
            -an {input.final_nucflag} \
            -o {output.qc_report} 2> {log}
        """

# ==============================================================================
# 10. Final Targets & Rule All
# ==============================================================================
def get_all_targets():
    targets = []
    targets.extend(expand(os.path.join(OUTDIR, "{sample}", 'QC_report.xls'), sample=SAMPLES))
    
    if rollback_mode == 1:
        targets.extend(expand(os.path.join(OUTDIR, "{sample}", 'repaired_assembly.afterRB.fa'), sample=SAMPLES))
        targets.extend(expand(rules.afterRB_merge_nucflag_errors.output.merged_dir, sample=SAMPLES))
    else:
        targets.extend(expand(os.path.join(OUTDIR, "{sample}", 'repaired_assembly.fa'), sample=SAMPLES))
        targets.extend(expand(rules.repaired_merge_nucflag_errors.output.merged_dir, sample=SAMPLES))
        
    return targets

rule all:
    input:
        get_all_targets()
    default_target: True
