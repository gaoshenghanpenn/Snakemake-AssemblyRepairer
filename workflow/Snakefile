# ==============================================================================
# 5. Checkpoint & Repair
# ==============================================================================
checkpoint split_repair_task:
    input:
        match_file = rules.run_get_target_and_second_region.output.repair_table,
    output:
        split_dir = directory(os.path.join(OUTDIR, "{sample}", "out_repair"))
    run:
        import os

        if not os.path.exists(output.split_dir):
            os.makedirs(output.split_dir)

        contigs_repair_record = {}

        with open(input.match_file, 'r') as f:
            while True:
                line = f.readline()[:-1]
                if not line:
                    break
                items = line.split('\t')
                name = items[0] + ':' + items[1] + '-' + items[2] + '@' + items[3]
                if name not in contigs_repair_record:
                    contigs_repair_record[name] = [line]
                else:
                    contigs_repair_record[name].append(line)
        
        for name in contigs_repair_record.keys():
            out_repair_file_name = os.path.join(output.split_dir, f"{name}.repair.xls")
            with open(out_repair_file_name, 'w') as out_repair_file:
                for j in contigs_repair_record[name]:
                    out_repair_file.write(j + '\n')


rule run_single_repair_job:
    input:
        repair_xls = os.path.join(OUTDIR, "{sample}", "out_repair", "{name}.repair.xls"),
        target_cen_array = lambda w: os.path.join(OUTDIR, w.sample, "target_cen_array", w.name.split('@')[0] + ".fa"),
        second_asm_array = rules.run_get_target_and_second_region.output.second_asm_array,
        error_dir = rules.target_merge_nucflag_errors.output.merged_dir,
        second_error_dir = rules.second_merge_nucflag_errors.output.merged_dir
    output:
        repaired_fa = os.path.join(OUTDIR, "{sample}", "repaired_results", "{name}.repaired.fa"),
        repaired_log = os.path.join(OUTDIR, "{sample}", "repaired_results", "{name}.repaired.log")
    log:
        os.path.join(LOGS_DIR, "{sample}", "run_single_repair_job", "{name}.log")
    benchmark:
        os.path.join(BMKS_DIR, "{sample}", "run_single_repair_job", "{name}.tsv")
    params:
        kmer_size = kmer_size,
        kmer_number = kmer_number,
        extend_length = extend_length,
        out_dir = lambda w: os.path.join(OUTDIR, w.sample, "repaired_results") 
    threads: 1
    shell:
        """
        REGION=$(echo "{wildcards.name}" | cut -d'@' -f1)
        FLAG=$(echo "{wildcards.name}" | cut -d'@' -f2)
        
        ERROR_FILE="{input.error_dir}/$REGION.xls"

        if [ ! -f "$ERROR_FILE" ]; then
            ERROR_FILE="-1"
        fi

        python workflow/script/region_repairment.py \
            -r {input.repair_xls} \
            -ts {input.target_cen_array} \
            -tf "$FLAG" \
            -te "$ERROR_FILE" \
            -ssd {input.second_asm_array} \
            -sed {input.second_error_dir} \
            -omd {params.out_dir} \
            -os {output.repaired_fa} \
            -ol {output.repaired_log} \
            -k {params.kmer_size} \
            -kn {params.kmer_number} \
            -et {params.extend_length} 2> {log}
        """

def get_repair_targets(wildcards):
    checkpoint_output = checkpoints.split_repair_task.get(sample=wildcards.sample).output.split_dir
    names, = glob_wildcards(os.path.join(checkpoint_output, "{name}.repair.xls"))
    return expand(os.path.join(OUTDIR, "{sample}", "repaired_results", "{name}.repaired.fa"), sample=wildcards.sample, name=names)

rule merge_and_repair_assembly:
    input:
        target_ref = get_target_ref,
        repaired_fragments = get_repair_targets
    output:
        out_bed = os.path.join(OUTDIR, "{sample}", 'repaired.bed'),
        out_fa  = os.path.join(OUTDIR, "{sample}", 'repaired_assembly.fa')
    log:
        os.path.join(LOGS_DIR, "{sample}", "merge_and_repair_assembly.log")
    benchmark:
        os.path.join(BMKS_DIR, "{sample}", "merge_and_repair_assembly.tsv")
    params:
        repair_dir = lambda w: os.path.join(OUTDIR, w.sample, "repaired_results"),
        out_dir_path = lambda w: os.path.join(OUTDIR, w.sample)
    threads: 1
    shell:
        """
        python workflow/script/repair_assembly.py \
            -r {input.target_ref} \
            -a {params.repair_dir} \
            -o {params.out_dir_path} \
            -or {output.out_bed} \
            -of {output.out_fa} 2> {log}
        """

