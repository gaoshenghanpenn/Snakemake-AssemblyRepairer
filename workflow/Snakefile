# 7. Rollback (optional)
# ==============================================================================
rule get_rollback_info:
    input:
        repair_bed = rules.merge_and_repair_assembly.output.out_bed,
        old_region_error_dir = rules.target_merge_nucflag_errors.output.merged_dir,
        new_region_error_dir = rules.repaired_merge_nucflag_errors.output.merged_dir,
    output:
        out_rollback_bed = os.path.join(OUTDIR, "{sample}", 'rollback.bed'),
    log:
        os.path.join(LOGS_DIR, "{sample}", "get_rollback_info.log")
    benchmark:
        os.path.join(BMKS_DIR, "{sample}", "get_rollback_info.tsv") 
    threads: 1
    shell:
        """
        python workflow/script/make_roll_back.py \
            -r {input.repair_bed} \
            -or {input.old_region_error_dir} \
            -nr {input.new_region_error_dir} \
            -o {output.out_rollback_bed} 2> {log}
        """

rule run_rollback:
    input:
        rollback_bed = rules.get_rollback_info.output.out_rollback_bed,
        target_ref = get_target_ref,
        repaired_fragments = get_repair_targets,
    output:
        repaired_assembly = os.path.join(OUTDIR, "{sample}", 'repaired_assembly.afterRB.fa'),
        final_bed = os.path.join(OUTDIR, "{sample}", 'repaired.afterRB.bed')
    log:
        os.path.join(LOGS_DIR, "{sample}", "run_rollback.log")
    benchmark:
        os.path.join(BMKS_DIR, "{sample}", "run_rollback.tsv")
    params:
        outdir = lambda w: os.path.join(OUTDIR, w.sample),
        repairdir = lambda w: os.path.join(OUTDIR, w.sample, "repaired_results"),
    threads: 1
    shell:
        """
        python workflow/script/rollback.py \
            -rb {input.rollback_bed} \
            -r {input.target_ref} \
            -a {params.repairdir} \
            -o {params.outdir} \
            -or {output.final_bed} \
            -of {output.repaired_assembly} 2> {log}
        """

